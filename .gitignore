# .gitignore for Electro

# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/
*.exe
*.app

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Local data (don't commit user data)
*.local.json
local_data/

# Logs
*.log
logs/

# Environment
.env
.env.local

# Next.js
.next/
out/

# PocketBase — pb_data contains the SQLite DB + admin credentials, NEVER commit
infra/pocketbase/pb_data/
# PocketBase binary is large — already gitignored, re-download via preflight-check.sh
infra/pocketbase/pocketbase

# Bun
bun.lockb
.gstack/

# Playwright — CI artifacts and MCP session files (don't commit)
test-results/
playwright-report/
.playwright-mcp/

# QA screenshots captured during testing sessions
qa-*.png

# TypeScript incremental build info
tsconfig.tsbuildinfo
